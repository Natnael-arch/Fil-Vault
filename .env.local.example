# Required: Get your HuggingFace API key at https://huggingface.co/settings/tokens
HF_API_KEY=your_hf_api_key_here

# Required: Get your Groq API key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Optional: Filebase S3-compatible IPFS/Filecoin storage
# Get API keys at https://console.filebase.com/
# If not set, the app uses an in-memory fallback with mock CIDs for demo flow
FILEBASE_ACCESS_KEY=
FILEBASE_SECRET_KEY=
FILEBASE_BUCKET=
